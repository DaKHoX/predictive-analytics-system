def build_machine_oee_comparison(engine: Engine, cfg: Config) -> pd.DataFrame:
    query = f"""
        SELECT
            day_key,
            machine_model,
            machine_tab_number,
            oee,
            availability,
            performance,
            quality,
            downtime_min
        FROM {table_name(cfg, 'oee_daily_metrics')}
        WHERE oee IS NOT NULL;
    """

    df = pd.read_sql(query, engine)

    if df.empty:
        print("Нет данных для сравнения OEE по табельным номерам.")
        return pd.DataFrame()

    df["day_key"] = pd.to_datetime(df["day_key"])
    df["oee"] = pd.to_numeric(df["oee"], errors="coerce")
    df["downtime_min"] = pd.to_numeric(df["downtime_min"], errors="coerce").fillna(0)

    latest_day = df["day_key"].max()
    latest_df = df[df["day_key"] == latest_day].copy()

    history = (
        df.groupby(["machine_model", "machine_tab_number"], as_index=False)
        .agg(
            oee_all_time_mean=("oee", "mean"),
            oee_all_time_min=("oee", "min"),
            oee_all_time_max=("oee", "max"),
            total_observation_days=("day_key", "nunique"),
            total_downtime_min=("downtime_min", "sum"),
        )
    )

    latest = (
        latest_df.groupby(["machine_model", "machine_tab_number"], as_index=False)
        .agg(
            latest_day=("day_key", "max"),
            oee_today=("oee", "mean"),
            availability_today=("availability", "mean"),
            performance_today=("performance", "mean"),
            quality_today=("quality", "mean"),
            downtime_today_min=("downtime_min", "sum"),
        )
    )

    comparison = latest.merge(
        history,
        on=["machine_model", "machine_tab_number"],
        how="left",
    )

    comparison["oee_today_deviation_from_mean"] = (
        comparison["oee_today"] - comparison["oee_all_time_mean"]
    )

    comparison["oee_today_relative_deviation_from_mean"] = np.where(
        comparison["oee_all_time_mean"] > 0,
        comparison["oee_today_deviation_from_mean"] / comparison["oee_all_time_mean"],
        np.nan,
    )

    comparison = comparison.sort_values(
        by=["oee_today", "oee_today_deviation_from_mean"],
        ascending=[True, True],
    )

    cfg.reports_dir.mkdir(parents=True, exist_ok=True)

    comparison_path = cfg.reports_dir / "oee_machine_comparison.xlsx"
    comparison.to_excel(comparison_path, index=False)

    print(f"Сравнение OEE по табельным номерам сохранено: {comparison_path}")
    print(f"Последний день в данных: {latest_day.date()}")

    return comparison

def print_weekly_deviation_summary(report_df: pd.DataFrame, cfg: Config) -> None:
    if report_df.empty:
        print("Недельный отчёт пуст, краткая статистика не сформирована.")
        return

    growth_df = report_df[
        report_df["deviation_status"].isin(
            ["существенный рост простоев", "умеренный рост простоев"]
        )
    ].copy()

    decline_df = report_df[
        report_df["deviation_status"].eq("снижение простоев")
    ].copy()

    top_growth = growth_df.head(10)

    lines = []

    week_start = report_df["report_week_start"].iloc[0]
    week_end = report_df["report_week_end"].iloc[0]

    lines.append(f"Краткая статистика за отчётную неделю: {week_start} — {week_end}")
    lines.append("")
    lines.append(f"Всего событий с отклонениями вверх: {len(growth_df)}")
    lines.append(f"Всего событий со снижением простоев: {len(decline_df)}")
    lines.append("")

    if not top_growth.empty:
        lines.append("Наибольший рост простоев относительно исторического среднего:")

        for _, row in top_growth.iterrows():
            rel = row["relative_deviation"]
            rel_text = "нет данных" if pd.isna(rel) else f"{rel * 100:.1f}%"

            lines.append(
                f"- {row['machine_model']} № {row['machine_tab_number']}: "
                f"{row['event_name']} — "
                f"{row['current_week_loss_min']:.2f} мин за неделю; "
                f"историческое среднее: {row['historical_week_avg_loss_min']:.2f} мин; "
                f"отклонение: {row['absolute_deviation_min']:.2f} мин ({rel_text})."
            )
    else:
        lines.append("Рост простоев относительно исторического среднего не выявлен.")

    summary_text = "\n".join(lines)

    print("\n" + summary_text)

    cfg.reports_dir.mkdir(parents=True, exist_ok=True)

    summary_path = cfg.reports_dir / "weekly_deviation_summary.txt"
    summary_path.write_text(summary_text, encoding="utf-8")

    print(f"Краткая статистика сохранена: {summary_path}")

def plot_weekly_deviation_top_events(report_df: pd.DataFrame, cfg: Config) -> None:
    if report_df.empty:
        print("Нет данных для построения графика недельных отклонений.")
        return

    plot_df = report_df.dropna(subset=["absolute_deviation_min"]).copy()

    if plot_df.empty:
        print("Нет рассчитанных отклонений для построения графика.")
        return

    # Берём события с самым большим отклонением по модулю:
    # как в сторону роста простоев, так и в сторону снижения.
    plot_df["abs_deviation_module"] = plot_df["absolute_deviation_min"].abs()

    plot_df = (
        plot_df
        .sort_values("abs_deviation_module", ascending=False)
        .head(15)
        .sort_values("absolute_deviation_min", ascending=True)
    )

    # Формируем подпись для оси Y
    plot_df["label"] = (
        plot_df["machine_model"].astype(str)
        + " № "
        + plot_df["machine_tab_number"].astype(str)
        + " | "
        + plot_df["event_name"].astype(str)
    )

    # Текстовая интерпретация направления отклонения
    plot_df["deviation_direction"] = np.where(
        plot_df["absolute_deviation_min"] > 0,
        "рост простоев",
        np.where(
            plot_df["absolute_deviation_min"] < 0,
            "снижение простоев",
            "без отклонения"
        )
    )

    cfg.reports_dir.mkdir(parents=True, exist_ok=True)

    ax = plot_df.plot(
        kind="barh",
        x="label",
        y="absolute_deviation_min",
        figsize=(13, 8),
        legend=False,
    )

    # Нулевая линия: справа от неё рост простоев, слева — снижение.
    ax.axvline(0, linewidth=1)

    ax.set_title("Отклонение простоев за последнюю отчётную неделю от исторического среднего")
    ax.set_xlabel("Отклонение от исторического среднего, мин")
    ax.set_ylabel("Станок и событие")
    ax.grid(True, axis="x")

    # Подписи на столбцах с явным знаком + или -
    for container in ax.containers:
        labels = []

        for value in container.datavalues:
            if value > 0:
                labels.append(f"+{value:.1f} мин")
            elif value < 0:
                labels.append(f"{value:.1f} мин")
            else:
                labels.append("0 мин")

        ax.bar_label(
            container,
            labels=labels,
            padding=3,
            fontsize=8
        )

    # Пояснение под графиком
    ax.text(
        0.5,
        -0.12,
        "Положительное значение означает рост простоев; отрицательное — снижение относительно исторического среднего.",
        transform=ax.transAxes,
        ha="center",
        fontsize=9
    )

    plt.tight_layout()

    output_path = cfg.reports_dir / "weekly_deviation_top_events.png"
    plt.savefig(output_path, dpi=300, bbox_inches="tight")
    plt.show()

    print(f"График недельных отклонений сохранён: {output_path}")

def send_email_with_attachments(
    cfg: Config,
    subject: str,
    body: str,
    attachment_paths: list[Path],
) -> None:
    smtp_user = os.getenv(cfg.smtp_user_env)
    smtp_password = os.getenv(cfg.smtp_password_env)

    if not smtp_user or not smtp_password:
        print(
            "Письмо не отправлено: не заданы переменные окружения "
            f"{cfg.smtp_user_env} и/или {cfg.smtp_password_env}."
        )
        return

    valid_attachments = [
        Path(path)
        for path in attachment_paths
        if path is not None and Path(path).exists()
    ]

    if not valid_attachments:
        print("Письмо не отправлено: нет файлов для вложения.")
        return

    message = EmailMessage()
    message["From"] = smtp_user
    message["To"] = cfg.email_recipient
    message["Subject"] = subject
    message.set_content(body)

    for path in valid_attachments:
        mime_type, _ = mimetypes.guess_type(path)

        if mime_type:
            maintype, subtype = mime_type.split("/", 1)
        else:
            maintype, subtype = "application", "octet-stream"

        with open(path, "rb") as file:
            message.add_attachment(
                file.read(),
                maintype=maintype,
                subtype=subtype,
                filename=path.name,
            )

    with smtplib.SMTP(cfg.smtp_host, cfg.smtp_port) as smtp:
        smtp.starttls()
        smtp.login(smtp_user, smtp_password)
        smtp.send_message(message)

    print(f"Письмо с графиками отправлено на адрес: {cfg.email_recipient}")


# 9. ДИАГНОСТИКА ПОДКЛЮЧЕНИЯ
def print_database_diagnostics(engine: Engine, cfg: Config) -> None:
    with engine.connect() as conn:
        db_name = conn.execute(text("SELECT current_database()")).scalar()
        current_schema = conn.execute(text("SELECT current_schema()")).scalar()

        count_events = conn.execute(
            text(f"SELECT COUNT(*) FROM {table_name(cfg, 'oee_event_records')}")
        ).scalar()

        count_metrics = conn.execute(
            text(f"SELECT COUNT(*) FROM {table_name(cfg, 'oee_monthly_metrics')}")
        ).scalar()

        count_daily = conn.execute(
            text(f"SELECT COUNT(*) FROM {table_name(cfg, 'oee_daily_metrics')}")
        ).scalar()

    print("\nДиагностика PostgreSQL:")
    print(f"База данных: {db_name}")
    print(f"Текущая схема по умолчанию: {current_schema}")
    print(f'Строк в "{cfg.db_schema}".oee_event_records: {count_events}')
    print(f'Строк в "{cfg.db_schema}".oee_monthly_metrics: {count_metrics}')
    print(f'Строк в "{cfg.db_schema}".oee_daily_metrics: {count_daily}')


# 10. ОБЩИЙ ЗАПУСК

def run_pipeline(cfg: Config) -> None:
    cfg.reports_dir.mkdir(parents=True, exist_ok=True)

    engine = get_engine(cfg)

    create_tables(engine, cfg)

    records_df, errors_df = read_all_excel_files(cfg)

    print("\nПредварительный просмотр загружаемых данных:")
    print(records_df.head())

    load_to_postgres(records_df, errors_df, engine, cfg)

    print_database_diagnostics(engine, cfg)

    # 1. Расчёт дневного OEE
    daily_df = calculate_daily_oee(engine, cfg)

    print("\nИтоговые дневные значения OEE:")
    print(daily_df)

    # 2. Отчёт по отклонениям простоев в разрезе событий
    weekly_deviation_df = build_weekly_deviation_report(engine, cfg)

    print("\nОтклонения последней отчётной недели от исторического среднего:")
    print(weekly_deviation_df.head(20))

    # 3. Краткая текстовая статистика по простоям
    print_weekly_deviation_summary(weekly_deviation_df, cfg)

    # 4. График отклонений по событиям, мин
    plot_weekly_deviation_top_events(weekly_deviation_df, cfg)

    # 5. Новый отчёт: средний недельный OEE по каждому станку
    #    и отклонение от исторического среднего OEE
    weekly_oee_deviation_df = build_weekly_oee_deviation_report(engine, cfg)

    print("\nСредний OEE за последнюю отчётную неделю по станкам:")
    print(weekly_oee_deviation_df)

    # 6. Новый график: недельный OEE и отклонение от исторического уровня
    weekly_oee_chart_path = plot_weekly_oee_deviation_by_machine(
        weekly_oee_deviation_df,
        cfg,
    )

    # 7. Путь к графику отклонений простоев
    weekly_deviation_chart_path = cfg.reports_dir / "weekly_deviation_top_events.png"

    attachments = []

    if weekly_deviation_chart_path.exists():
        attachments.append(weekly_deviation_chart_path)
    else:
        print(f"График отклонений простоев не найден: {weekly_deviation_chart_path}")

    if weekly_oee_chart_path is not None and Path(weekly_oee_chart_path).exists():
        attachments.append(weekly_oee_chart_path)
    else:
        print("График недельного OEE не найден или не был сформирован.")

    send_email_with_attachments(
        cfg=cfg,
        subject="OEE: недельный отчёт по станкам",
        body=(
            "Добрый день.\n\n"
            "Во вложении направлены графики по результатам недельного анализа OEE.\n\n"
            "В отчёт включены:\n"
            "1. отклонения простоев по событиям относительно исторического среднего;\n"
            "2. средний OEE за последнюю отчётную неделю по каждому станку "
            "и отклонение от исторического значения.\n\n"
            "Отчёт сформирован автоматически."
        ),
        attachment_paths=attachments,
    )

    print_database_diagnostics(engine, cfg)

    print("\nОбработка завершена.")


if __name__ == "__main__":
    run_pipeline(CFG)
