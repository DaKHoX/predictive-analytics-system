def build_weekly_oee_deviation_report(engine: Engine, cfg: Config) -> pd.DataFrame:
    """
    Рассчитывает средний OEE за последнюю отчётную неделю по каждому станку
    и сравнивает его с историческим средним недельным OEE.
    """

    query = f"""
        SELECT
            day_key,
            machine_model,
            machine_tab_number,
            planned_time_min,
            downtime_min,
            actual_work_time_min,
            availability,
            performance,
            quality,
            oee
        FROM {table_name(cfg, 'oee_daily_metrics')}
        ORDER BY day_key, machine_model, machine_tab_number;
    """

    df = pd.read_sql(query, engine)

    if df.empty:
        print("Нет строк в oee_daily_metrics для расчёта недельного OEE.")
        return pd.DataFrame()

    df["day_key"] = pd.to_datetime(df["day_key"], errors="coerce")

    numeric_cols = [
        "planned_time_min",
        "downtime_min",
        "actual_work_time_min",
        "availability",
        "performance",
        "quality",
        "oee",
    ]

    for col in numeric_cols:
        df[col] = pd.to_numeric(df[col], errors="coerce")

    df = df.dropna(subset=["day_key"])

    # Если OEE не рассчитался, используем availability как временную оценку OEE.
    # Это допустимо для тестового контура, если нет полноценного выпуска и качества.
    df["oee_for_week"] = df["oee"]

    df["oee_for_week"] = df["oee_for_week"].fillna(df["availability"])

    calculated_availability = np.where(
        df["planned_time_min"] > 0,
        (df["planned_time_min"] - df["downtime_min"]) / df["planned_time_min"],
        np.nan,
    )

    df["oee_for_week"] = df["oee_for_week"].fillna(
        pd.Series(calculated_availability, index=df.index)
    )

    df = df.dropna(subset=["oee_for_week"])

    if df.empty:
        print("В oee_daily_metrics есть строки, но нет значений для расчёта недельного OEE.")
        return pd.DataFrame()

    report_week_end = df["day_key"].max().normalize()
    report_week_start = report_week_end - pd.Timedelta(days=6)

    current_df = df[
        (df["day_key"] >= report_week_start)
        & (df["day_key"] <= report_week_end)
    ].copy()

    history_df = df[df["day_key"] < report_week_start].copy()

    if current_df.empty:
        print("За последнюю отчётную неделю нет данных OEE.")
        return pd.DataFrame()

    group_cols = ["machine_model", "machine_tab_number"]

    current_week = (
        current_df
        .groupby(group_cols, as_index=False)
        .agg(
            current_week_oee=("oee_for_week", "mean"),
            current_week_availability=("availability", "mean"),
            current_week_performance=("performance", "mean"),
            current_week_quality=("quality", "mean"),
            current_week_downtime_min=("downtime_min", "sum"),
            observation_days=("day_key", "nunique"),
        )
    )

    if history_df.empty:
        result = current_week.copy()
        result["historical_week_oee"] = np.nan
        result["historical_week_downtime_min"] = np.nan
        result["historical_weeks_count"] = 0
        result["absolute_deviation_pp"] = np.nan
        result["relative_deviation_percent"] = np.nan
        result["oee_status"] = "нет исторических данных"
    else:
        history_df["week_start"] = (
            history_df["day_key"]
            - pd.to_timedelta(history_df["day_key"].dt.weekday, unit="D")
        ).dt.normalize()

        historical_weekly = (
            history_df
            .groupby(group_cols + ["week_start"], as_index=False)
            .agg(
                weekly_oee=("oee_for_week", "mean"),
                weekly_downtime_min=("downtime_min", "sum"),
            )
        )

        historical_avg = (
            historical_weekly
            .groupby(group_cols, as_index=False)
            .agg(
                historical_week_oee=("weekly_oee", "mean"),
                historical_week_downtime_min=("weekly_downtime_min", "mean"),
                historical_weeks_count=("week_start", "nunique"),
            )
        )

        result = current_week.merge(
            historical_avg,
            on=group_cols,
            how="left",
        )

        result["absolute_deviation_pp"] = (
            result["current_week_oee"] - result["historical_week_oee"]
        ) * 100

        result["relative_deviation_percent"] = np.where(
            result["historical_week_oee"] > 0,
            (
                (result["current_week_oee"] - result["historical_week_oee"])
                / result["historical_week_oee"]
            ) * 100,
            np.nan,
        )

        def classify_oee_deviation(row) -> str:
            deviation_pp = row["absolute_deviation_pp"]

            if pd.isna(deviation_pp):
                return "нет исторического среднего"

            if deviation_pp <= -10:
                return "существенное снижение OEE"

            if deviation_pp <= -5:
                return "умеренное снижение OEE"

            if deviation_pp >= 5:
                return "рост OEE"

            return "в пределах исторического уровня"

        result["oee_status"] = result.apply(classify_oee_deviation, axis=1)

    result["report_week_start"] = report_week_start.date()
    result["report_week_end"] = report_week_end.date()

    result["current_week_oee_percent"] = result["current_week_oee"] * 100
    result["historical_week_oee_percent"] = result["historical_week_oee"] * 100
    result["current_week_availability_percent"] = result["current_week_availability"] * 100
    result["current_week_performance_percent"] = result["current_week_performance"] * 100
    result["current_week_quality_percent"] = result["current_week_quality"] * 100

    ordered_cols = [
        "report_week_start",
        "report_week_end",
        "machine_model",
        "machine_tab_number",
        "observation_days",
        "current_week_oee_percent",
        "historical_week_oee_percent",
        "absolute_deviation_pp",
        "relative_deviation_percent",
        "current_week_availability_percent",
        "current_week_performance_percent",
        "current_week_quality_percent",
        "current_week_downtime_min",
        "historical_week_downtime_min",
        "historical_weeks_count",
        "oee_status",
    ]

    result = result[ordered_cols].copy()

    numeric_cols = [
        "current_week_oee_percent",
        "historical_week_oee_percent",
        "absolute_deviation_pp",
        "relative_deviation_percent",
        "current_week_availability_percent",
        "current_week_performance_percent",
        "current_week_quality_percent",
        "current_week_downtime_min",
        "historical_week_downtime_min",
    ]

    for col in numeric_cols:
        result[col] = pd.to_numeric(result[col], errors="coerce").round(2)

    result = result.sort_values(
        by=["current_week_oee_percent"],
        ascending=True,
        na_position="last",
    )

    cfg.reports_dir.mkdir(parents=True, exist_ok=True)

    report_path = cfg.reports_dir / "weekly_oee_deviation_report.xlsx"
    result.to_excel(report_path, index=False)

    result.to_sql(
        "oee_weekly_oee_deviation_report",
        engine,
        schema=cfg.db_schema,
        if_exists="replace",
        index=False,
        method="multi",
        chunksize=1000,
    )

    print(f"Недельный отчёт OEE сохранён: {report_path}")
    print(f"Отчётная неделя: {report_week_start.date()} — {report_week_end.date()}")

    return result

def build_weekly_oee_report(
    engine: Engine,
    cfg: Config,
    report_week_start,
    report_week_end,
) -> pd.DataFrame:
    """
    Формирует отчёт по фактическому OEE за ту же неделю,
    которая используется для анализа отклонений простоев.
    """

    query = f"""
        SELECT
            day_key,
            machine_model,
            machine_tab_number,
            planned_time_min,
            downtime_min,
            actual_work_time_min,
            actual_output,
            standard_output,
            good_qty,
            defect_qty,
            availability,
            performance,
            quality,
            oee
        FROM {table_name(cfg, 'oee_daily_metrics')}
        WHERE day_key BETWEEN :week_start AND :week_end
          AND oee IS NOT NULL
        ORDER BY day_key, machine_model, machine_tab_number;
    """

    df = pd.read_sql(
        text(query),
        engine,
        params={
            "week_start": report_week_start,
            "week_end": report_week_end,
        },
    )

    if df.empty:
        print("Нет данных для расчёта недельного OEE.")
        return pd.DataFrame()

    numeric_cols = [
        "planned_time_min",
        "downtime_min",
        "actual_work_time_min",
        "actual_output",
        "standard_output",
        "good_qty",
        "defect_qty",
        "availability",
        "performance",
        "quality",
        "oee",
    ]

    for col in numeric_cols:
        df[col] = pd.to_numeric(df[col], errors="coerce").fillna(0)

    group_cols = ["machine_model", "machine_tab_number"]

    weekly_df = (
        df
        .groupby(group_cols, as_index=False)
        .agg(
            observation_days=("day_key", "nunique"),
            planned_time_min=("planned_time_min", "sum"),
            downtime_min=("downtime_min", "sum"),
            actual_work_time_min=("actual_work_time_min", "sum"),
            actual_output=("actual_output", "sum"),
            standard_output=("standard_output", "sum"),
            good_qty=("good_qty", "sum"),
            defect_qty=("defect_qty", "sum"),
            daily_oee_mean=("oee", "mean"),
        )
    )

    weekly_df["availability_week"] = np.where(
        weekly_df["planned_time_min"] > 0,
        weekly_df["actual_work_time_min"] / weekly_df["planned_time_min"],
        np.nan,
    )

    weekly_df["performance_week"] = np.where(
        weekly_df["standard_output"] > 0,
        weekly_df["actual_output"] / weekly_df["standard_output"],
        np.nan,
    )

    weekly_df["quality_week"] = np.where(
        weekly_df["actual_output"] > 0,
        weekly_df["good_qty"] / weekly_df["actual_output"],
        np.nan,
    )

    weekly_df["oee_week"] = (
        weekly_df["availability_week"]
        * weekly_df["performance_week"]
        * weekly_df["quality_week"]
    )

    weekly_df["oee_percent"] = weekly_df["oee_week"] * 100
    weekly_df["availability_percent"] = weekly_df["availability_week"] * 100
    weekly_df["performance_percent"] = weekly_df["performance_week"] * 100
    weekly_df["quality_percent"] = weekly_df["quality_week"] * 100
    weekly_df["daily_oee_mean_percent"] = weekly_df["daily_oee_mean"] * 100

    weekly_df["oee_target_percent"] = cfg.oee_target * 100
    weekly_df["oee_deviation_pp"] = (
        weekly_df["oee_percent"] - weekly_df["oee_target_percent"]
    )

    weekly_df["report_week_start"] = pd.to_datetime(report_week_start).date()
    weekly_df["report_week_end"] = pd.to_datetime(report_week_end).date()

    ordered_cols = [
        "report_week_start",
        "report_week_end",
        "machine_model",
        "machine_tab_number",
        "observation_days",
        "planned_time_min",
        "downtime_min",
        "actual_work_time_min",
        "actual_output",
        "standard_output",
        "good_qty",
        "defect_qty",
        "availability_percent",
        "performance_percent",
        "quality_percent",
        "oee_percent",
        "daily_oee_mean_percent",
        "oee_target_percent",
        "oee_deviation_pp",
    ]

    weekly_df = weekly_df[ordered_cols].copy()

    for col in weekly_df.columns:
        if col not in ["report_week_start", "report_week_end", "machine_model", "machine_tab_number"]:
            weekly_df[col] = pd.to_numeric(weekly_df[col], errors="ignore")

    round_cols = [
        "planned_time_min",
        "downtime_min",
        "actual_work_time_min",
        "actual_output",
        "standard_output",
        "good_qty",
        "defect_qty",
        "availability_percent",
        "performance_percent",
        "quality_percent",
        "oee_percent",
        "daily_oee_mean_percent",
        "oee_target_percent",
        "oee_deviation_pp",
    ]

    for col in round_cols:
        weekly_df[col] = pd.to_numeric(weekly_df[col], errors="coerce").round(2)

    weekly_df = weekly_df.sort_values(
        by=["oee_percent", "downtime_min"],
        ascending=[True, False],
    )

    cfg.reports_dir.mkdir(parents=True, exist_ok=True)

    weekly_oee_path = cfg.reports_dir / "oee_weekly_oee_report.xlsx"
    weekly_df.to_excel(weekly_oee_path, index=False)

    weekly_df.to_sql(
        "oee_weekly_oee_report",
        engine,
        schema=cfg.db_schema,
        if_exists="replace",
        index=False,
        method="multi",
        chunksize=1000,
    )

    print(f"Недельный отчёт OEE сохранён: {weekly_oee_path}")

    return weekly_df

