def build_weekly_deviation_report(engine: Engine, cfg: Config) -> pd.DataFrame:
    """
    Сравнивает последнюю отчётную неделю с исторически накопленными данными.

    Последняя отчётная неделя определяется как 7 календарных дней,
    заканчивающихся максимальной датой, найденной в oee_event_records.
    Историческая база сравнения — все данные до начала последней отчётной недели.
    """

    query = f"""
        SELECT
            month_key,
            year_num,
            month_num,
            day_num,
            machine_model,
            machine_tab_number,
            loss_block,
            event_name,
            normalized_event_name,
            analytic_block,
            duration_min
        FROM {table_name(cfg, 'oee_event_records')}
        WHERE LOWER(loss_block) <> 'итоговый показатель блока'
          AND day_num IS NOT NULL;
    """

    df = pd.read_sql(query, engine)

    if df.empty:
        print("Нет данных для недельного анализа отклонений.")
        return pd.DataFrame()

    df["duration_min"] = pd.to_numeric(df["duration_min"], errors="coerce").fillna(0)

    df["year_num"] = pd.to_numeric(df["year_num"], errors="coerce")
    df["month_num"] = pd.to_numeric(df["month_num"], errors="coerce")
    df["day_num"] = pd.to_numeric(df["day_num"], errors="coerce")

    df = df.dropna(subset=["year_num", "month_num", "day_num"])

    df["event_date"] = pd.to_datetime(
        dict(
            year=df["year_num"].astype(int),
            month=df["month_num"].astype(int),
            day=df["day_num"].astype(int),
        ),
        errors="coerce",
    )

    df = df.dropna(subset=["event_date"])

    # Исключаем строки выпуска и результата, чтобы анализировать именно простои и потери
    service_events = {
        "изготовление изделий",
        "исправные изделия",
        "изделия несоответствующие установленному качеству",
    }

    df["event_key"] = (
        df["event_name"]
        .astype(str)
        .str.lower()
        .str.strip()
        .str.replace("ё", "е", regex=False)
    )

    df = df[~df["event_key"].isin(service_events)].copy()

    if df.empty:
        print("После исключения строк выпуска не осталось данных для анализа простоев.")
        return pd.DataFrame()

    report_week_end = df["event_date"].max().normalize()
    report_week_start = report_week_end - pd.Timedelta(days=6)

    current_df = df[
        (df["event_date"] >= report_week_start)
        & (df["event_date"] <= report_week_end)
    ].copy()

    history_df = df[df["event_date"] < report_week_start].copy()

    if current_df.empty:
        print("За последнюю отчётную неделю нет событий для анализа.")
        return pd.DataFrame()

    group_cols = [
        "machine_model",
        "machine_tab_number",
        "loss_block",
        "event_name",
        "normalized_event_name",
        "analytic_block",
    ]

    current_week = (
        current_df
        .groupby(group_cols, as_index=False)
        .agg(
            current_week_loss_min=("duration_min", "sum"),
            current_week_event_count=("duration_min", "count"),
            current_avg_event_duration_min=("duration_min", "mean"),
        )
    )

    if history_df.empty:
        current_week["historical_week_avg_loss_min"] = np.nan
        current_week["historical_week_avg_event_count"] = np.nan
        current_week["historical_avg_event_duration_min"] = np.nan
        current_week["absolute_deviation_min"] = np.nan
        current_week["relative_deviation"] = np.nan
        current_week["deviation_status"] = "нет исторических данных"
        result = current_week.copy()
    else:
        # Приводим исторические данные к недельным суммам.
        # Это важно: сравниваем последнюю неделю не со средним днём,
        # а со средней неделей за всё предыдущее время.
        history_df["week_start"] = (
            history_df["event_date"]
            - pd.to_timedelta(history_df["event_date"].dt.weekday, unit="D")
        ).dt.normalize()

        historical_weekly = (
            history_df
            .groupby(group_cols + ["week_start"], as_index=False)
            .agg(
                weekly_loss_min=("duration_min", "sum"),
                weekly_event_count=("duration_min", "count"),
                weekly_avg_event_duration_min=("duration_min", "mean"),
            )
        )

        historical_avg = (
            historical_weekly
            .groupby(group_cols, as_index=False)
            .agg(
                historical_week_avg_loss_min=("weekly_loss_min", "mean"),
                historical_week_avg_event_count=("weekly_event_count", "mean"),
                historical_avg_event_duration_min=("weekly_avg_event_duration_min", "mean"),
            )
        )

        result = current_week.merge(
            historical_avg,
            on=group_cols,
            how="left",
        )

        result["absolute_deviation_min"] = (
            result["current_week_loss_min"]
            - result["historical_week_avg_loss_min"]
        )

        result["relative_deviation"] = np.where(
            result["historical_week_avg_loss_min"] > 0,
            result["absolute_deviation_min"] / result["historical_week_avg_loss_min"],
            np.nan,
        )

        def classify_deviation(row) -> str:
            rel = row["relative_deviation"]
            abs_dev = row["absolute_deviation_min"]

            if pd.isna(rel):
                return "нет исторического среднего"

            if rel >= 0.5 and abs_dev > 0:
                return "существенный рост простоев"

            if rel >= 0.2 and abs_dev > 0:
                return "умеренный рост простоев"

            if rel <= -0.2:
                return "снижение простоев"

            return "в пределах исторического уровня"

        result["deviation_status"] = result.apply(classify_deviation, axis=1)

    result["report_week_start"] = report_week_start.date()
    result["report_week_end"] = report_week_end.date()

    ordered_cols = [
        "report_week_start",
        "report_week_end",
        "machine_model",
        "machine_tab_number",
        "loss_block",
        "event_name",
        "normalized_event_name",
        "analytic_block",
        "current_week_loss_min",
        "historical_week_avg_loss_min",
        "absolute_deviation_min",
        "relative_deviation",
        "current_week_event_count",
        "historical_week_avg_event_count",
        "current_avg_event_duration_min",
        "historical_avg_event_duration_min",
        "deviation_status",
    ]

    result = result[ordered_cols].copy()

    numeric_cols = [
        "current_week_loss_min",
        "historical_week_avg_loss_min",
        "absolute_deviation_min",
        "relative_deviation",
        "historical_week_avg_event_count",
        "current_avg_event_duration_min",
        "historical_avg_event_duration_min",
    ]

    for col in numeric_cols:
        result[col] = pd.to_numeric(result[col], errors="coerce").round(4)

    result = result.sort_values(
        by=["absolute_deviation_min", "current_week_loss_min"],
        ascending=[False, False],
        na_position="last",
    )

    with engine.begin() as conn:
