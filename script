# 3. ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
def quote_ident(identifier: str) -> str:
    return '"' + identifier.replace('"', '""') + '"'


def table_name(cfg: Config, name: str) -> str:
    return f"{quote_ident(cfg.db_schema)}.{name}"


def col_letter_to_index(col_letter: str) -> int:
    col_letter = col_letter.upper().strip()
    result = 0

    for char in col_letter:
        result = result * 26 + (ord(char) - ord("A") + 1)

    return result - 1


def clean_text(value) -> str:
    if pd.isna(value):
        return ""
    return str(value).strip()


def normalize_key(value) -> str:
    return clean_text(value).lower().replace("ё", "е")


def safe_to_datetime(value):
    if pd.isna(value):
        return pd.NaT
    return pd.to_datetime(value, errors="coerce", dayfirst=True)


def get_numeric(value, default: float = 0.0) -> float:
    if pd.isna(value):
        return default

    try:
        return float(str(value).replace(",", "."))
    except ValueError:
        return default


def get_event_info(event_name: str) -> dict:
    key = normalize_key(event_name)

    return EVENT_DICTIONARY.get(
        key,
        {
            "normalized_event": event_name,
            "analytic_block": "прочее",
            "owner_group": "production_manager",
        },
    )


def parse_file_info(file_path: Path, data_dir: Path) -> dict:
    """
    Ожидаемая структура:

    Data/
        Аггрегатный станок/
            234859/
                Аггрегатный станок,234859,01.24.xlsm

    Модель станка берётся из папки первого уровня.
    Табельный номер берётся из папки второго уровня.
    Месяц и год берутся из имени Excel-файла.
    """

    relative_path = file_path.resolve().relative_to(data_dir.resolve())

    if len(relative_path.parts) < 3:
        raise ValueError(
            f"Некорректное расположение файла: {file_path}. "
            f"Ожидается структура: Data/модель_станка/табельный_номер/файл.xlsm"
        )

    machine_model = relative_path.parts[0]
    machine_tab_number = relative_path.parts[1]

    stem = file_path.stem
    parts = [part.strip() for part in stem.split(",")]

    # Основной формат: Аггрегатный станок,234859,01.24
    if len(parts) >= 3:
        date_part = parts[2].rstrip(".")
    else:
        # Допустимый короткий вариант: 01.24
        date_part = stem.strip().rstrip(".")

    date_parts = date_part.split(".")

    if len(date_parts) != 2:
        raise ValueError(
            f"Некорректная дата в имени файла: {file_path.name}. "
            f"Ожидаемый формат: ММ.ГГ, например 01.24"
        )

    month_num = int(date_parts[0])
    year_num = 2000 + int(date_parts[1])

    if month_num < 1 or month_num > 12:
        raise ValueError(f"Некорректный месяц в имени файла: {file_path.name}")

    return {
        "machine_model": machine_model,
        "machine_tab_number": machine_tab_number,
        "month_num": month_num,
        "year_num": year_num,
        "month_key": pd.Timestamp(year=year_num, month=month_num, day=1).date(),
    }


# 4. ПОДКЛЮЧЕНИЕ И СОЗДАНИЕ ТАБЛИЦ
def get_engine(cfg: Config) -> Engine:
    return create_engine(cfg.db_url)


def create_tables(engine: Engine, cfg: Config) -> None:
    schema = quote_ident(cfg.db_schema)

    drop_sql = f"""
    DROP TABLE IF EXISTS {schema}.oee_load_errors CASCADE;
    DROP TABLE IF EXISTS {schema}.oee_monthly_metrics CASCADE;
    DROP TABLE IF EXISTS {schema}.oee_event_records CASCADE;
    """

    create_sql = f"""
    CREATE SCHEMA IF NOT EXISTS {schema};

    CREATE TABLE IF NOT EXISTS {schema}.oee_event_records (
        id BIGSERIAL PRIMARY KEY,

        source_file_name TEXT NOT NULL,
        source_file_path TEXT NOT NULL,
        source_sheet_name TEXT NOT NULL,
        source_row_number INTEGER NOT NULL,
        source_pair_label TEXT NOT NULL,

        month_key DATE NOT NULL,
        month_num INTEGER NOT NULL,
        year_num INTEGER NOT NULL,
        day_num INTEGER,

        machine_model TEXT NOT NULL,
        machine_tab_number TEXT NOT NULL,

        loss_block TEXT NOT NULL,
        event_name TEXT NOT NULL,
        normalized_event_name TEXT,
        analytic_block TEXT,
        owner_group TEXT,

        start_time TIMESTAMP NULL,
        end_time TIMESTAMP NULL,
        duration_min NUMERIC(12, 2) NOT NULL DEFAULT 0,
        has_time_interval BOOLEAN NOT NULL DEFAULT FALSE,

        quantity_value NUMERIC(12, 2) DEFAULT 0,
        good_qty NUMERIC(12, 2) DEFAULT 0,
        defect_qty NUMERIC(12, 2) DEFAULT 0,
        actual_output NUMERIC(12, 2) DEFAULT 0,

        planned_time_min NUMERIC(12, 2) DEFAULT 0,
        standard_time_per_unit_min NUMERIC(12, 4) DEFAULT 1,

        loaded_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,

        CONSTRAINT chk_oee_time_interval
            CHECK (
                (start_time IS NULL AND end_time IS NULL)
                OR
                (start_time IS NOT NULL AND end_time IS NOT NULL AND end_time >= start_time)
            ),

        CONSTRAINT chk_oee_duration_non_negative
            CHECK (duration_min >= 0)
    );

    CREATE TABLE IF NOT EXISTS {schema}.oee_monthly_metrics (
        id BIGSERIAL PRIMARY KEY,

        month_key DATE NOT NULL,

        machine_model TEXT NOT NULL,
        machine_tab_number TEXT NOT NULL,

        planned_time_min NUMERIC(12, 2),
        downtime_min NUMERIC(12, 2),
        actual_work_time_min NUMERIC(12, 2),

        actual_output NUMERIC(12, 2),
        standard_output NUMERIC(12, 2),
        good_qty NUMERIC(12, 2),
        defect_qty NUMERIC(12, 2),

        availability NUMERIC(10, 4),
        performance NUMERIC(10, 4),
        quality NUMERIC(10, 4),
        oee NUMERIC(10, 4),

        oee_target NUMERIC(10, 4),
        oee_deviation NUMERIC(10, 4),
        oee_relative_deviation NUMERIC(10, 4),

        calculated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
    );
    CREATE TABLE IF NOT EXISTS {schema}.oee_daily_metrics (
        id BIGSERIAL PRIMARY KEY,

        day_key DATE NOT NULL,
        month_key DATE NOT NULL,

        machine_model TEXT NOT NULL,
        machine_tab_number TEXT NOT NULL,

        planned_time_min NUMERIC(12, 2),
        downtime_min NUMERIC(12, 2),
        actual_work_time_min NUMERIC(12, 2),

        actual_output NUMERIC(12, 2),
        standard_output NUMERIC(12, 2),
        good_qty NUMERIC(12, 2),
        defect_qty NUMERIC(12, 2),

        availability NUMERIC(10, 4),
        performance NUMERIC(10, 4),
        quality NUMERIC(10, 4),
        oee NUMERIC(10, 4),

        oee_target NUMERIC(10, 4),
        oee_deviation NUMERIC(10, 4),
        oee_relative_deviation NUMERIC(10, 4),

        calculated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
    );

    CREATE INDEX IF NOT EXISTS idx_oee_daily_day
        ON {schema}.oee_daily_metrics (day_key);

    CREATE INDEX IF NOT EXISTS idx_oee_daily_machine
        ON {schema}.oee_daily_metrics (machine_model, machine_tab_number);

    CREATE INDEX IF NOT EXISTS idx_oee_daily_machine_day
        ON {schema}.oee_daily_metrics (machine_model, machine_tab_number, day_key);
        
    CREATE TABLE IF NOT EXISTS {schema}.oee_load_errors (
        id BIGSERIAL PRIMARY KEY,

        source_file_name TEXT,
        source_file_path TEXT,
        source_sheet_name TEXT,
        source_row_number INTEGER,
        source_pair_label TEXT,

        error_type TEXT,
        error_details TEXT,

        created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
    );

    CREATE INDEX IF NOT EXISTS idx_oee_event_month
        ON {schema}.oee_event_records (month_key);

    CREATE INDEX IF NOT EXISTS idx_oee_event_machine
        ON {schema}.oee_event_records (machine_model, machine_tab_number);

    CREATE INDEX IF NOT EXISTS idx_oee_event_machine_month
        ON {schema}.oee_event_records (machine_model, machine_tab_number, month_key);

    CREATE INDEX IF NOT EXISTS idx_oee_event_loss_block
        ON {schema}.oee_event_records (loss_block);
    """

    with engine.begin() as conn:
        if cfg.recreate_tables:
            conn.execute(text(drop_sql))
        conn.execute(text(create_sql))


# 5. ЧТЕНИЕ EXCEL И ФОРМИРОВАНИЕ ЗАПИСЕЙ
def build_records_from_sheet(
    df: pd.DataFrame,
    file_path: Path,
    sheet_name: str,
    cfg: Config,
) -> tuple[pd.DataFrame, pd.DataFrame]:

    file_info = parse_file_info(file_path, cfg.data_dir)

    loss_idx = col_letter_to_index(cfg.loss_block_col)
    event_idx = col_letter_to_index(cfg.event_col)
    quantity_idx = col_letter_to_index(cfg.quantity_col) if cfg.quantity_col else None

    # Если в столбце блока потерь используются объединённые ячейки,
    # pandas прочитает нижние строки как пустые. Поэтому блок потерь протягивается вниз.
    if loss_idx < len(df.columns):
        df.iloc[:, loss_idx] = df.iloc[:, loss_idx].ffill()

    try:
        day_num = int(sheet_name)
    except ValueError:
        day_num = None

    records: list[dict] = []
    errors: list[dict] = []

    first_idx = cfg.first_data_row - 1
    last_idx = min(cfg.last_data_row - 1, len(df) - 1)

    for row_idx in range(first_idx, last_idx + 1):
        row = df.iloc[row_idx]

        loss_block = clean_text(row.iloc[loss_idx]) if loss_idx < len(row) else ""
        event_name = clean_text(row.iloc[event_idx]) if event_idx < len(row) else ""

        if not event_name:
            continue

        if normalize_key(loss_block) == cfg.skip_loss_block:
            continue

        event_info = get_event_info(event_name)

        quantity_value = 0.0
        if quantity_idx is not None and quantity_idx < len(row):
            quantity_value = get_numeric(row.iloc[quantity_idx], default=0.0)

        has_valid_interval = False
        has_any_time_value = False

        for start_col, end_col in cfg.time_pairs:
            start_idx = col_letter_to_index(start_col)
            end_idx = col_letter_to_index(end_col)

            start_raw = row.iloc[start_idx] if start_idx < len(row) else None
            end_raw = row.iloc[end_idx] if end_idx < len(row) else None

            pair_label = f"{start_col}-{end_col}"

            if not pd.isna(start_raw) or not pd.isna(end_raw):
                has_any_time_value = True

            start_time = safe_to_datetime(start_raw)
            end_time = safe_to_datetime(end_raw)

            if pd.isna(start_time) and pd.isna(end_time):
                continue

            if pd.isna(start_time) or pd.isna(end_time):
                errors.append(
                    {
                        "source_file_name": file_path.name,
                        "source_file_path": str(file_path),
                        "source_sheet_name": sheet_name,
                        "source_row_number": row_idx + 1,
                        "source_pair_label": pair_label,
                        "error_type": "partial_time_interval",
                        "error_details": "Заполнено только начало или только конец временного интервала",
                    }
                )
                continue

            if end_time < start_time:
                errors.append(
                    {
                        "source_file_name": file_path.name,
                        "source_file_path": str(file_path),
                        "source_sheet_name": sheet_name,
                        "source_row_number": row_idx + 1,
                        "source_pair_label": pair_label,
                        "error_type": "invalid_time_interval",
                        "error_details": "Окончание раньше начала",
                    }
                )
                continue

            duration_min = round((end_time - start_time).total_seconds() / 60, 2)

            records.append(
                {
                    "source_file_name": file_path.name,
                    "source_file_path": str(file_path),
                    "source_sheet_name": sheet_name,
                    "source_row_number": row_idx + 1,
                    "source_pair_label": pair_label,

                    "month_key": file_info["month_key"],
                    "month_num": file_info["month_num"],
                    "year_num": file_info["year_num"],
                    "day_num": day_num,

                    "machine_model": file_info["machine_model"],
                    "machine_tab_number": file_info["machine_tab_number"],

                    "loss_block": loss_block,
                    "event_name": event_name,
                    "normalized_event_name": event_info["normalized_event"],
                    "analytic_block": event_info["analytic_block"],
                    "owner_group": event_info["owner_group"],

                    "start_time": start_time.to_pydatetime(),
                    "end_time": end_time.to_pydatetime(),
                    "duration_min": duration_min,
                    "has_time_interval": True,

                    "quantity_value": quantity_value,
                    "good_qty": 0.0,
                    "defect_qty": 0.0,
                    "actual_output": 0.0,

                    "planned_time_min": 0.0,
                    "standard_time_per_unit_min": cfg.default_standard_time_per_unit_min,
                }
            )

            has_valid_interval = True

        # Если по событию нет ни одного временного показателя, записываем его с нулевой длительностью.
        if not has_valid_interval and not has_any_time_value:
            records.append(
                {
                    "source_file_name": file_path.name,
                    "source_file_path": str(file_path),
                    "source_sheet_name": sheet_name,
                    "source_row_number": row_idx + 1,
                    "source_pair_label": "NO_TIME",

                    "month_key": file_info["month_key"],
                    "month_num": file_info["month_num"],
                    "year_num": file_info["year_num"],
                    "day_num": day_num,

                    "machine_model": file_info["machine_model"],
                    "machine_tab_number": file_info["machine_tab_number"],

                    "loss_block": loss_block,
                    "event_name": event_name,
                    "normalized_event_name": event_info["normalized_event"],
                    "analytic_block": event_info["analytic_block"],
                    "owner_group": event_info["owner_group"],

                    "start_time": None,
                    "end_time": None,
                    "duration_min": 0.0,
                    "has_time_interval": False,

                    "quantity_value": quantity_value,
                    "good_qty": 0.0,
                    "defect_qty": 0.0,
                    "actual_output": 0.0,

                    "planned_time_min": 0.0,
                    "standard_time_per_unit_min": cfg.default_standard_time_per_unit_min,
                }
            )

    return pd.DataFrame(records), pd.DataFrame(errors)


def read_all_excel_files(cfg: Config) -> tuple[pd.DataFrame, pd.DataFrame]:
    """
    Читает Excel-файлы из структуры:

    Data/
        Аггрегатный станок/
            234859/
                Аггрегатный станок,234859,01.24.xlsm
    """

    excel_files = sorted(
        [
            *cfg.data_dir.glob("*/*/*.xlsx"),
            *cfg.data_dir.glob("*/*/*.xlsm"),
        ]
    )

    excel_files = [p for p in excel_files if not p.name.startswith("~$")]

    print("Найденные Excel-файлы:")
    for file in excel_files:
        print(f"  {file}")

    if not excel_files:
        raise FileNotFoundError(
            f"В папке {cfg.data_dir.resolve()} не найдены Excel-файлы. "
            f"Ожидаемая структура: Data/модель_станка/табельный_номер/файл.xlsm"
        )

    all_records = []
    all_errors = []

    for file_path in excel_files:
        print(f"\nЧтение файла: {file_path}")

        for sheet_num in range(cfg.first_sheet, cfg.last_sheet + 1):
            sheet_name = str(sheet_num)

            try:
                df = pd.read_excel(
                    file_path,
                    sheet_name=sheet_name,
                    header=None,
                    usecols="A:L",
                    engine="openpyxl",
                )
            except ValueError:
                continue

            records_df, errors_df = build_records_from_sheet(
                df=df,
                file_path=file_path,
                sheet_name=sheet_name,
                cfg=cfg,
            )

            if not records_df.empty:
                all_records.append(records_df)

            if not errors_df.empty:
                all_errors.append(errors_df)

    records = pd.concat(all_records, ignore_index=True) if all_records else pd.DataFrame()
    errors = pd.concat(all_errors, ignore_index=True) if all_errors else pd.DataFrame()

    return records, errors


# 6. ЗАГРУЗКА В POSTGRESQL
def load_to_postgres(
    records_df: pd.DataFrame,
    errors_df: pd.DataFrame,
    engine: Engine,
    cfg: Config,
) -> None:

    if records_df.empty:
        print("Нет записей для загрузки в PostgreSQL.")
        return

    loaded_file_paths = records_df["source_file_path"].dropna().unique().tolist()

    with engine.begin() as conn:
        if cfg.clear_existing_for_loaded_files:
            for file_path in loaded_file_paths:
                conn.execute(
                    text(f"DELETE FROM {table_name(cfg, 'oee_event_records')} WHERE source_file_path = :source_file_path"),
                    {"source_file_path": file_path},
                )
                conn.execute(
                    text(f"DELETE FROM {table_name(cfg, 'oee_load_errors')} WHERE source_file_path = :source_file_path"),
                    {"source_file_path": file_path},
                )

    records_df.to_sql(
        "oee_event_records",
        engine,
        schema=cfg.db_schema,
        if_exists="append",
        index=False,
        method="multi",
        chunksize=1000,
    )

    if not errors_df.empty:
        errors_df.to_sql(
            "oee_load_errors",
            engine,
            schema=cfg.db_schema,
            if_exists="append",
            index=False,
            method="multi",
            chunksize=1000,
        )

    print(f"Загружено записей событий: {len(records_df)}")
    print(f"Записей с ошибками: {len(errors_df)}")


# 7. РАСЧЁТ OEE
def calculate_monthly_oee(engine: Engine, cfg: Config) -> pd.DataFrame:
    query = f"""
        SELECT
            month_key,
            machine_model,
            machine_tab_number,
            loss_block,
            event_name,
            normalized_event_name,
            analytic_block,
            duration_min,
            quantity_value,
            standard_time_per_unit_min
        FROM {table_name(cfg, 'oee_event_records')};
    """

    df = pd.read_sql(query, engine)

    if df.empty:
        print("В таблице oee_event_records нет данных для расчёта OEE.")
        return pd.DataFrame()

    df["event_key"] = (
        df["event_name"]
        .astype(str)
        .str.lower()
        .str.strip()
        .str.replace("ё", "е", regex=False)
    )

    df["duration_min"] = pd.to_numeric(df["duration_min"], errors="coerce").fillna(0)
    df["quantity_value"] = pd.to_numeric(df["quantity_value"], errors="coerce").fillna(0)

    result_rows = []
    group_cols = ["month_key", "machine_model", "machine_tab_number"]

    for (month_key, machine_model, machine_tab_number), group in df.groupby(group_cols):
        productive_mask = group["event_key"].eq("изготовление изделий")
        break_mask = group["event_key"].eq("установленные перерывы")
        good_mask = group["event_key"].eq("исправные изделия")
        defect_mask = group["event_key"].eq("изделия несоответствующие установленному качеству")

        # Потери: всё, кроме изготовления, перерывов и строк результата выпуска.
        downtime_mask = ~(productive_mask | break_mask | good_mask | defect_mask)

        downtime_min = float(group.loc[downtime_mask, "duration_min"].sum())
        productive_time_min = float(group.loc[productive_mask, "duration_min"].sum())

        # В текущей версии плановое время принимается как производительное время + потери.
        # Если появится отдельный норматив планового времени, этот блок можно заменить.
        planned_time_min = productive_time_min + downtime_min
        actual_work_time_min = productive_time_min

        actual_output_from_qty = float(group.loc[productive_mask, "quantity_value"].sum())
        good_qty_from_qty = float(group.loc[good_mask, "quantity_value"].sum())
        defect_qty_from_qty = float(group.loc[defect_mask, "quantity_value"].sum())

        actual_output = actual_output_from_qty
        good_qty = good_qty_from_qty
        defect_qty = defect_qty_from_qty

        # Тестовая оценка, если отдельный столбец количества не задан.
        if actual_output == 0:
            actual_output = float(productive_mask.sum())

        if good_qty == 0:
            good_qty = float(good_mask.sum())

        if defect_qty == 0:
            defect_qty = float(defect_mask.sum())

        if actual_output == 0 and (good_qty + defect_qty) > 0:
            actual_output = good_qty + defect_qty

        if good_qty == 0 and actual_output > 0 and defect_qty == 0:
            good_qty = actual_output

        standard_time_per_unit_min = float(
            pd.to_numeric(group["standard_time_per_unit_min"], errors="coerce")
            .dropna()
            .mean()
        )

        if standard_time_per_unit_min <= 0:
            standard_time_per_unit_min = cfg.default_standard_time_per_unit_min

        standard_output = (
            actual_work_time_min / standard_time_per_unit_min
            if standard_time_per_unit_min > 0
            else np.nan
        )

        availability = (
            actual_work_time_min / planned_time_min
            if planned_time_min > 0
            else np.nan
        )

        performance = (
            actual_output / standard_output
            if standard_output and standard_output > 0
            else np.nan
        )

        quality = (
            good_qty / actual_output
            if actual_output > 0
            else np.nan
        )

        oee = availability * performance * quality

        oee_deviation = oee - cfg.oee_target if pd.notna(oee) else np.nan
        oee_relative_deviation = (
            oee_deviation / cfg.oee_target
            if cfg.oee_target > 0 and pd.notna(oee_deviation)
            else np.nan
        )

        result_rows.append(
            {
                "month_key": month_key,

                "machine_model": machine_model,
                "machine_tab_number": machine_tab_number,

                "planned_time_min": round(planned_time_min, 2),
                "downtime_min": round(downtime_min, 2),
                "actual_work_time_min": round(actual_work_time_min, 2),

                "actual_output": round(actual_output, 2),
                "standard_output": round(standard_output, 2) if pd.notna(standard_output) else None,
                "good_qty": round(good_qty, 2),
                "defect_qty": round(defect_qty, 2),

                "availability": round(availability, 4) if pd.notna(availability) else None,
                "performance": round(performance, 4) if pd.notna(performance) else None,
                "quality": round(quality, 4) if pd.notna(quality) else None,
                "oee": round(oee, 4) if pd.notna(oee) else None,

                "oee_target": cfg.oee_target,
                "oee_deviation": round(oee_deviation, 4) if pd.notna(oee_deviation) else None,
                "oee_relative_deviation": round(oee_relative_deviation, 4) if pd.notna(oee_relative_deviation) else None,
            }
        )

    metrics_df = pd.DataFrame(result_rows)

    with engine.begin() as conn:
        conn.execute(text(f"DELETE FROM {table_name(cfg, 'oee_monthly_metrics')}"))

    metrics_df.to_sql(
        "oee_monthly_metrics",
        engine,
        schema=cfg.db_schema,
        if_exists="append",
        index=False,
        method="multi",
        chunksize=1000,
    )

    cfg.reports_dir.mkdir(parents=True, exist_ok=True)

    metrics_path = cfg.reports_dir / "oee_monthly_metrics.xlsx"
    metrics_df.to_excel(metrics_path, index=False)

    print(f"Расчёт OEE выполнен. Отчёт сохранён: {metrics_path}")

    return metrics_df

